# Copy to .env and fill in. The erc20-vault integration suite prints a
# ready-to-paste block for the derived values on its first run — with nothing
# set, everything defaults to the local docker stack (docker-compose.yaml).

# --- Midnight endpoints (packages/lib/src/midnight-node-config.ts) ---
# Network (undeployed | stagenet | preview | preprod | mainnet); defaults to
# undeployed. Networks other than undeployed target a deployed network over
# its public RPC. The proof server always stays local (it sees private
# witness data).
NETWORK_ID=
# Endpoint overrides; default per NETWORK_ID (undeployed = the local docker
# stack in docker-compose.yaml; deployed networks = their public endpoints)
MIDNIGHT_NODE_URL=
MIDNIGHT_NODE_INDEXER_URL=
MIDNIGHT_NODE_INDEXER_WS_URL=
MIDNIGHT_NODE_PROOF_SERVER_URL=

# --- Wallets (one ROOT funds the role wallets) ---
# ROOT holds the funds and pays out to the role wallets; it does no test work.
# On undeployed it defaults to the genesis mint wallet. On a DEPLOYED network
# it is generated on the first run, which then STOPS at the root preflight and
# prints ROOT's NIGHT address to fund via the faucet (stagenet:
# https://faucet.stagenet.shielded.tools); a rerun funds the roles and proceeds.
ROOT_SEED=
# The role wallets (hex or mnemonic). Each is generated + persisted here
# on first run and funded from ROOT; set one to reuse it (skips generation):
#   deployer      - deploys the signet + vault contracts
#   user          - drives the vault's circuits and seeds the derived EVM
#                   account identity
#   mpc responder - the fakenet responder's fee-paying wallet
#   bearer        - the bearer-transfer flow's second spending wallet
DEPLOYER_SEED=
USER_SEED=
MPC_RESPONDER_SEED=
BEARER_SEED=
# NIGHT (base units) to move from ROOT into each role wallet that needs
# funding; unset splits ROOT's balance evenly across the wallets that need it.
FUND_CHILD_NIGHT=
# Vault deployer identity secret (32-byte hex, sealed into the contract as a
# commitment); optional — the setup defaults it to the USER identity secret
# (initialize is deployer-gated and the flows drive it as the user)
VAULT_DEPLOYER_SECRET_KEY=
# User identity secret answering the vault's callerSecretKey witness;
# optional — falls back to the USER_SEED bytes.
VAULT_USER_SECRET_KEY=

# --- Deployed contracts (printed by deploy / the integration suite) ---
MIDNIGHT_VAULT_CONTRACT_ADDRESS=
MIDNIGHT_SIGNET_CONTRACT_ADDRESS=

# --- MPC / fakenet signer (github.com/sig-net/solana-signet-program) ---
# Root key the fakenet signer holds; the two public keys derive from it
# (the integration suite generates + prints all three when unset)
MPC_ROOT_KEY=
MPC_SECP256K1_PUBKEY=
MPC_JUBJUB_PK=

# --- Derived EVM accounts (printed by the integration suite) ---
# Funded automatically on the local dev chain (chain id 31337).
# The vault's account (path "vault"); holds gas ETH for withdrawals
EVM_VAULT_ADDRESS=
# The user's account (path = identity commitment hex); holds ETH and the
# ERC20 balance the deposit flow spends
EVM_USER_ADDRESS=

# --- EVM ---
# JSON-RPC endpoint of the EVM chain; defaults to the local `evm` docker
# compose service (http://127.0.0.1:8545, part of `docker compose up -d`)
EVM_RPC_URL=
# Resolved from the RPC when unset; verified against it when set (loud failure
# on mismatch — the value is sealed into the vault at initialize)
EVM_CHAIN_ID=
# Token the deposit flow moves. On the local dev chain setup auto-deploys
# TestUSDC when the address has no code, and prints the value
ERC20_ADDRESS=

# --- Fakenet container (docker compose interpolates these) ---
# EVM endpoint as reachable FROM THE CONTAINER — both sides must point at
# the SAME chain. Defaults to the in-network anvil compose service.
#FAKENET_EVM_RPC_URL=http://evm:8545
# Midnight endpoints as reachable FROM THE CONTAINER; default to the local
# compose stack. On a deployed network (e.g. stagenet) point them at that
# network's public endpoints so the responder polls the same chain the tests
# use (the proof server stays the local compose service).
#MIDNIGHT_NETWORK_ID=
#MIDNIGHT_INDEXER_URL=
#MIDNIGHT_INDEXER_WS_URL=
#MIDNIGHT_NODE_URL=
#MIDNIGHT_PROOF_SERVER_URL=
# Set to 0 to run the responder yourself (responder development) — the
# setup then leaves the container and .env alone.
#FAKENET_MANAGED=0

# --- Resume (printed by a partial integration run) ---
# Request ids that let a rerun pick up an in-flight flow instead of creating
# a fresh request; each flow file prints its own on first creation.
#DEPOSIT_REQUEST_ID=
#WITHDRAW_REQUEST_ID=
#FAILURE_REFUND_DEPOSIT_REQUEST_ID=
#FAILURE_REFUND_WITHDRAW_REQUEST_ID=
#DEPOSIT_CLAIMANT_NOT_CALLER_DEPOSIT_REQUEST_ID=
